<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Dashboard - Social Connect' }) %>
</head>
<body class="app-page">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/dashboard"><i class="fas fa-users"></i> Social Connect</a>
      <div class="d-flex align-items-center gap-2">
        <a class="nav-link" href="/dashboard">Home</a>
        <a class="nav-link" href="/profile-page">Profile</a>
        <button class="btn btn-outline-danger btn-sm" type="button" onclick="logout()">Logout</button>
      </div>
    </div>
  </nav>

  <div class="container container-main">
    <div class="row g-4">
      <div class="col-lg-8">
        <div class="card card-app">
          <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-pen"></i> Create post</h5>
          </div>
          <div class="card-body">
            <form id="postForm">
              <div class="mb-3">
                <label class="form-label" for="title">Title</label>
                <input type="text" class="form-control" id="title" name="title" required maxlength="255">
              </div>
              <div class="mb-3">
                <label class="form-label" for="content">Content</label>
                <textarea class="form-control" id="content" name="content" rows="4" required></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label" for="images">Images</label>
                <input type="file" class="form-control" id="images" name="images" accept="image/*" multiple required>
                <div class="form-text">At least one image is required (uploaded to Cloudinary).</div>
              </div>
              <button type="submit" class="btn btn-gradient" id="postSubmitBtn">
                <i class="fas fa-paper-plane"></i> Publish
              </button>
            </form>
          </div>
        </div>

        <div id="feedMessage" class="alert d-none" role="alert"></div>
        <div id="posts-container"></div>
      </div>

      <div class="col-lg-4">
        <div class="profile-sidebar" id="sidebar">
          <div class="profile-avatar-lg" id="sidebarAvatar">?</div>
          <h4 class="fw-bold mb-1" id="sidebarUsername">—</h4>
          <p class="text-muted small mb-3" id="sidebarEmail">—</p>
          <p class="text-muted small mb-0" id="sidebarPostCount">0 posts</p>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content card-app">
        <div class="modal-header card-header">
          <h5 class="modal-title text-white"><i class="fas fa-edit"></i> Edit post</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form id="editForm">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label" for="editTitle">Title</label>
              <input type="text" class="form-control" id="editTitle" required>
            </div>
            <div class="mb-3">
              <label class="form-label" for="editContent">Content</label>
              <textarea class="form-control" id="editContent" rows="4" required></textarea>
            </div>
            <input type="hidden" id="editPostId">
          </div>
          <div class="modal-footer border-0">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-gradient">Save changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
  <script src="/js/api.js"></script>
  <script>
    if (!requireAuth()) throw new Error('redirect');

    const user = getUser();
    const postsContainer = document.getElementById('posts-container');
    const feedMessage = document.getElementById('feedMessage');
    let allPosts = [];
    let myPosts = [];

    function showFeedMessage(text, type) {
      feedMessage.className = `alert alert-${type}`;
      feedMessage.textContent = text;
      feedMessage.classList.remove('d-none');
      setTimeout(() => feedMessage.classList.add('d-none'), 4000);
    }

    function renderSidebar() {
      if (!user) return;
      document.getElementById('sidebarAvatar').textContent = (user.username || '?').charAt(0).toUpperCase();
      document.getElementById('sidebarUsername').textContent = user.username || 'User';
      document.getElementById('sidebarEmail').textContent = user.email || '';
      document.getElementById('sidebarPostCount').textContent = `${myPosts.length} post${myPosts.length === 1 ? '' : 's'}`;
    }

    function renderPosts(posts) {
      if (!posts.length) {
        postsContainer.innerHTML = `
          <div class="card card-app">
            <div class="card-body empty-state">
              <i class="fas fa-comments d-block"></i>
              <h4>No posts yet</h4>
              <p class="mb-0">Be the first to share something.</p>
            </div>
          </div>`;
        return;
      }

      postsContainer.innerHTML = posts.map((post) => {
        const isOwner = user && Number(user.id) === Number(post.user_id);
        const initial = (post.username || 'U').charAt(0).toUpperCase();
        return `
          <div class="card card-app post-card" data-post-id="${post.id}">
            <div class="card-body">
              <div class="d-flex align-items-start gap-3 mb-3">
                <div class="user-avatar">${initial}</div>
                <div class="flex-grow-1">
                  <h6 class="mb-0 fw-bold">@${post.username || 'user'}</h6>
                  <div class="post-meta"><i class="fas fa-clock"></i> ${formatDate(post.created_at)}</div>
                </div>
                ${isOwner ? `
                  <button type="button" class="btn btn-sm btn-outline-secondary edit-post-btn" data-id="${post.id}">
                    <i class="fas fa-edit"></i>
                  </button>` : ''}
              </div>
              <h5 class="fw-semibold post-title">${escapeHtml(post.title)}</h5>
              <p class="post-content mb-3">${escapeHtml(post.content)}</p>
              <button type="button" class="btn btn-outline-primary btn-sm like-btn" data-post-id="${post.id}">
                <i class="fas fa-heart"></i> Like (<span class="likes-count">${post.likes ?? 0}</span>)
              </button>
            </div>
          </div>`;
      }).join('');

      postsContainer.querySelectorAll('.like-btn').forEach((btn) => {
        btn.addEventListener('click', () => likePost(btn));
      });
      postsContainer.querySelectorAll('.edit-post-btn').forEach((btn) => {
        btn.addEventListener('click', () => openEditModal(btn.dataset.id));
      });
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function loadPosts() {
      const [{ response: feedRes, data: feedData }, { response: mineRes, data: mineData }] = await Promise.all([
        apiJson('/posts/', { headers: authHeaders() }),
        apiJson('/posts/mine', { headers: authHeaders() }),
      ]);

      if (feedRes.ok) {
        allPosts = feedData.posts || [];
        renderPosts(allPosts);
      } else {
        showFeedMessage(feedData.message || 'Could not load posts', 'danger');
      }

      if (mineRes.ok) {
        myPosts = mineData.posts || [];
      }
      renderSidebar();
    }

    document.getElementById('postForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('postSubmitBtn');
      btn.disabled = true;

      const formData = new FormData();
      formData.append('title', document.getElementById('title').value.trim());
      formData.append('content', document.getElementById('content').value.trim());
      const files = document.getElementById('images').files;
      for (const file of files) {
        formData.append('images', file);
      }

      try {
        const response = await fetch('/posts/createPost', {
          method: 'POST',
          headers: { Authorization: `Bearer ${getToken()}` },
          body: formData,
        });
        const data = await response.json();

        if (response.ok) {
          e.target.reset();
          showFeedMessage(data.message || 'Post created', 'success');
          await loadPosts();
        } else {
          showFeedMessage(data.message || 'Failed to create post', 'danger');
        }
      } catch {
        showFeedMessage('Something went wrong', 'danger');
      } finally {
        btn.disabled = false;
      }
    });

    async function likePost(btn) {
      const postId = btn.dataset.postId;
      btn.disabled = true;
      try {
        const { response, data } = await apiJson(`/posts/likePost/${postId}`, {
          method: 'POST',
          headers: authHeaders(),
        });
        if (response.ok) {
          const countEl = btn.querySelector('.likes-count');
          const likes = data.likepost?.likes ?? (parseInt(countEl.textContent, 10) + 1);
          countEl.textContent = likes;
          btn.classList.add('liked');
        } else {
          showFeedMessage(data.message || 'Could not like post', 'danger');
        }
      } catch {
        showFeedMessage('Something went wrong', 'danger');
      } finally {
        btn.disabled = false;
      }
    }

    let editModal;
    function openEditModal(postId) {
      const post = allPosts.find((p) => String(p.id) === String(postId));
      if (!post) return;
      document.getElementById('editPostId').value = post.id;
      document.getElementById('editTitle').value = post.title;
      document.getElementById('editContent').value = post.content;
      editModal = editModal || new bootstrap.Modal(document.getElementById('editModal'));
      editModal.show();
    }

    document.getElementById('editForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('editPostId').value;
      const body = {
        title: document.getElementById('editTitle').value.trim(),
        content: document.getElementById('editContent').value.trim(),
      };

      const { response, data } = await apiJson(`/posts/updatePost/${id}`, {
        method: 'PUT',
        headers: authHeaders(),
        body: JSON.stringify(body),
      });

      if (response.ok) {
        editModal.hide();
        showFeedMessage(data.message || 'Post updated', 'success');
        await loadPosts();
      } else {
        showFeedMessage(data.message || 'Update failed', 'danger');
      }
    });

    loadPosts();
  </script>
</body>
</html>

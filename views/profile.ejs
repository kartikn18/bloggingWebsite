<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Profile - Social Connect' }) %>
</head>
<body class="app-page">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/dashboard"><i class="fas fa-users"></i> Social Connect</a>
      <div class="d-flex align-items-center gap-2">
        <a class="nav-link" href="/dashboard">Home</a>
        <a class="nav-link" href="/profile-page">Profile</a>
        <button class="btn btn-outline-danger btn-sm" type="button" onclick="logout()">Logout</button>
      </div>
    </div>
  </nav>

  <div class="container container-main">
    <div class="card card-app mb-4">
      <div class="card-body text-center py-5">
        <div class="profile-avatar-lg mx-auto" id="profileAvatar">?</div>
        <h1 class="fw-bold mt-3" id="profileUsername">—</h1>
        <p class="text-muted" id="profileEmail">—</p>
        <div class="d-flex justify-content-center gap-4 mt-3">
          <div>
            <div class="fs-4 fw-bold text-primary" id="postCount">0</div>
            <div class="text-muted small">Posts</div>
          </div>
          <div>
            <div class="fs-4 fw-bold text-primary" id="totalLikes">0</div>
            <div class="text-muted small">Likes received</div>
          </div>
        </div>
        <a href="/dashboard" class="btn btn-gradient mt-4">
          <i class="fas fa-home"></i> Back to dashboard
        </a>
      </div>
    </div>

    <div class="card card-app">
      <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-newspaper"></i> My posts</h5>
      </div>
      <div class="card-body" id="myPostsContainer">
        <div class="empty-state">
          <i class="fas fa-spinner fa-spin d-block"></i>
          <p class="mb-0">Loading…</p>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
  <script src="/js/api.js"></script>
  <script>
    if (!requireAuth()) throw new Error('redirect');

    const user = getUser();
    const container = document.getElementById('myPostsContainer');

    if (user) {
      document.getElementById('profileAvatar').textContent = (user.username || '?').charAt(0).toUpperCase();
      document.getElementById('profileUsername').textContent = user.username || 'User';
      document.getElementById('profileEmail').textContent = user.email || '';
    }

    function renderMyPosts(posts) {
      document.getElementById('postCount').textContent = posts.length;
      const likes = posts.reduce((sum, p) => sum + (Number(p.likes) || 0), 0);
      document.getElementById('totalLikes').textContent = likes;

      if (!posts.length) {
        container.innerHTML = `
          <div class="empty-state">
            <i class="fas fa-edit d-block"></i>
            <h4>No posts yet</h4>
            <p class="mb-3">Create your first post from the dashboard.</p>
            <a href="/dashboard" class="btn btn-gradient">Create post</a>
          </div>`;
        return;
      }

      container.innerHTML = posts.map((post) => `
        <div class="border rounded-3 p-3 mb-3">
          <h5 class="fw-semibold">${escapeHtml(post.title)}</h5>
          <p class="mb-2">${escapeHtml(post.content)}</p>
          <div class="d-flex justify-content-between text-muted small">
            <span><i class="fas fa-clock"></i> ${formatDate(post.created_at)}</span>
            <span><i class="fas fa-heart text-danger"></i> ${post.likes ?? 0} likes</span>
          </div>
        </div>
      `).join('');
    }

    function escapeHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function loadMyPosts() {
      const { response, data } = await apiJson('/posts/mine', {
        headers: authHeaders(),
      });

      if (response.ok) {
        renderMyPosts(data.posts || []);
      } else {
        container.innerHTML = `
          <div class="alert alert-danger mb-0">
            ${data.message || 'Could not load your posts'}
          </div>`;
      }
    }

    loadMyPosts();
  </script>
</body>
</html>
